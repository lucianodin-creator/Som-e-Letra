<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SOM LETRAS PRO</title>
    <style>
        /* Visual Dark Mode */
        body { background: #000; color: #fff; font-family: sans-serif; margin: 0; padding: 0; }
        header { background: #111; padding: 20px; text-align: center; border-bottom: 2px solid #39ff14; }
        h1 { color: #39ff14; margin: 0; font-size: 22px; text-transform: uppercase; }
        
        /* Grade de Músicas */
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 15px; padding: 20px; }
        
        .card { background: #111; border: 1px solid #333; border-radius: 12px; overflow: hidden; cursor: pointer; text-align: center; transition: 0.3s; }
        .card:active { transform: scale(0.95); border-color: #39ff14; }
        
        /* Imagem com fundo de segurança se falhar */
        .card img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; border-bottom: 2px solid #39ff14; background: #222; }
        
        .info { padding: 10px; }
        .info strong { color: #39ff14; display: block; font-size: 14px; margin-bottom: 4px; }
        .info span { color: #ccc; font-size: 12px; }

        /* Player Overlay */
        #player { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #000; z-index: 1000; }
        .btn-voltar { background: #39ff14; color: #000; border: none; padding: 15px; width: 100%; font-weight: bold; font-size: 16px; }
    </style>
</head>
<body>

    <header><h1>SOM LETRAS PRO</h1></header>

    <div class="grid" id="musicGrid"></div>

    <div id="player">
        <button class="btn-voltar" onclick="fechar()">← VOLTAR PARA A LISTA</button>
        <div id="videoBox" style="width:100%; aspect-ratio:16/9; margin-top:20px;"></div>
    </div>

    <script>
        // Dados integrados para evitar erro de arquivo não encontrado
        const musicas = [
            { t: "Deixa a Vida Me Levar", a: "Zeca Pagodinho", id: "9S-70L_S9Xo" },
            { t: "Cheia de Manias", a: "Raça Negra", id: "F0vX7C0f-rc" },
            { t: "Verdade", a: "Zeca Pagodinho", id: "tuZ9HnIn9_E" },
            { t: "Coração em Desalinho", a: "Zeca Pagodinho", id: "R9_V9W2E2yA" },
            { t: "Vai Vadiar", a: "Zeca Pagodinho", id: "G_6v9W2E2yA" },
            { t: "É Tarde Demais", a: "Raça Negra", id: "88X9N_rL6-E" }
        ];

        function carregar() {
            const grid = document.getElementById('musicGrid');
            grid.innerHTML = musicas.map(m => {
                // O Proxy 'images.weserv.nl' busca a imagem para você e pula o bloqueio do Chrome/5G
                const proxyUrl = `https://images.weserv.nl/?url=https://i.ytimg.com/vi/${m.id}/mqdefault.jpg`;
                
                return `
                    <div class="card" onclick="tocar('${m.id}')">
                        <img src="${proxyUrl}" loading="lazy">
                        <div class="info">
                            <strong>${m.a}</strong>
                            <span>${m.t}</span>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function tocar(id) {
            document.getElementById('player').style.display = 'block';
            document.getElementById('videoBox').innerHTML = `<iframe src="https://www.youtube.com/embed/${id}?autoplay=1" style="width:100%; height:100%;" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe>`;
        }

        function fechar() {
            document.getElementById('player').style.display = 'none';
            document.getElementById('videoBox').innerHTML = "";
        }

        window.onload = carregar;
    </script>
</body>
</html>
